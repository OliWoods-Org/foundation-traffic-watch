# foundation-traffic-watch environment variables

PORT=3847
NODE_ENV=development

# Supabase (optional — for persistent storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Alert channels (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
RESEND_API_KEY=

# AI analysis (optional — local LLM preferred for survivor data)
ANTHROPIC_API_KEY=